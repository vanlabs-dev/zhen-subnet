# Zhen Subnet Configuration
# Copy to .env and modify as needed

# Network settings
ZHEN_NETUID=456
ZHEN_NETWORK=test

# Wallet (can also use CLI args)
ZHEN_WALLET_NAME=zhen-miner
ZHEN_WALLET_HOTKEY=default

# BOPTEST settings (validator only, non-local mode)
BOPTEST_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO
